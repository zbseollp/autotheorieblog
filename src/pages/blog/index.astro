---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts, displayTitle, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getHomepagePosts();
---
<!-- Archief: editoriaal genummerd lijstoverzicht -->
<BaseLayout
  title={`Alle artikelen — theorie tips & uitleg | ${SITE.name}`}
  description="Het complete archief van Autotheorieblog.nl — alle artikelen over het CBR theorie-examen."
>
  <Container class="py-(--spacing-section)">

    <!-- Archief header editorial -->
    <div class="mb-10 text-center">
      <div class="text-xs font-bold uppercase tracking-[0.4em] text-brand-700 mb-2">Archief</div>
      <h1 style="font-family: var(--font-heading);" class="text-4xl font-bold text-slate-900 sm:text-5xl">Alle artikelen</h1>
      <div class="mt-4 flex items-center gap-4 justify-center">
        <div class="h-px w-16 bg-slate-900"></div>
        <span class="text-sm text-slate-500">{posts.length} artikelen over het CBR theorie-examen</span>
        <div class="h-px w-16 bg-slate-900"></div>
      </div>
    </div>

    <div class="grid gap-0 lg:grid-cols-3 lg:divide-x lg:divide-slate-200">
      <!-- Artikelenlijst: 2/3 breed -->
      <div class="lg:col-span-2 lg:pr-10">
        {posts.map((p) => <BlogPostCard post={p} />)}
      </div>

      <!-- Sidebar: 1/3 -->
      <div class="mt-10 lg:mt-0 lg:pl-10 border-t border-slate-200 pt-8 lg:border-t-0 lg:pt-0">
        <h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-6">Onderwerpen</h2>
        <ul class="space-y-2">
          {[
            { label: "Gevaarherkenning", href: "/blog/" },
            { label: "Voorrangsregels", href: "/theorie-uitleg/" },
            { label: "Verkeerstekens", href: "/theorie-uitleg/" },
            { label: "Rijbewijs halen", href: "/rijbewijs-halen/" },
            { label: "Examen tips", href: "/blog/" },
            { label: "Code 95", href: "/blog/" },
          ].map((t) => (
            <li>
              <a href={t.href} class="flex items-center gap-3 border-b border-slate-100 py-2 text-sm text-slate-700 hover:text-brand-700 transition-colors group">
                <span class="h-px flex-1 bg-slate-200 group-hover:bg-brand-300 transition-colors"></span>
                {t.label}
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-10 border-t-2 border-slate-900 pt-6">
          <div class="border-t border-slate-300 mb-4"></div>
          <p style="font-family: var(--font-heading);" class="text-lg font-bold text-slate-900">Theorie uitleg nodig?</p>
          <p class="mt-2 text-sm text-slate-600">Bekijk onze uitlegpagina's over verkeersregels en het CBR-examen.</p>
          <a href="/theorie-uitleg/" class="mt-4 inline-flex w-full items-center justify-center border-2 border-brand-700 px-4 py-2.5 text-sm font-bold text-brand-700 hover:bg-brand-700 hover:text-white transition-colors">
            Theorie uitleg →
          </a>
        </div>
      </div>
    </div>
  </Container>
</BaseLayout>
