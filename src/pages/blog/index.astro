---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getHomepagePosts();
const [lead, ...rest] = posts;
const leadTitle = lead ? displayTitle(lead) : "";
const leadDesc = lead ? displayDescription(lead) : "";
---
<!-- Layout: paarse header + lead volledig breed + 3-koloms grid -->
<BaseLayout
  title={`Blog — theorie artikelen & tips | ${SITE.name}`}
  description="Lees alle artikelen over het CBR theorie-examen: tips, uitleg, verkeersborden en meer."
>
  <section class="border-b border-brand-100 bg-[linear-gradient(180deg,var(--color-brand-50)_0%,#fff_80%)]">
    <Container class="py-(--spacing-section)">
      <span class="text-xs font-bold uppercase tracking-widest text-brand-700">Autotheorieblog.nl</span>
      <h1 class="mt-1 text-4xl font-extrabold tracking-tight text-slate-900">Alle artikelen</h1>
      <p class="mt-3 max-w-xl text-slate-600">Praktische tips en uitleg over het CBR theorie-examen — gratis lezen.</p>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">
    {/* Uitgelicht artikel: groot bovenaan */}
    {lead && (
      <a href={`/${lead.id}/`}
         class="group mb-10 flex flex-col overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:shadow-xl lg:flex-row">
        {lead.data.featuredImage ? (
          <img src={lead.data.featuredImage} alt={leadTitle}
               width="800" height="450" loading="eager" fetchpriority="high"
               class="h-56 w-full object-cover lg:h-72 lg:w-2/5 group-hover:brightness-95 transition" />
        ) : (
          <div class="h-56 w-full bg-gradient-to-br from-brand-700 to-brand-400 lg:h-72 lg:w-2/5 flex items-center justify-center">
            <span class="text-3xl font-extrabold text-white/20">BLOG</span>
          </div>
        )}
        <div class="flex flex-1 flex-col justify-center p-8">
          <div class="flex items-center gap-3 mb-2">
            <span class="rounded-full bg-brand-100 px-3 py-1 text-xs font-bold text-brand-700">Uitgelicht</span>
            <time class="text-xs text-slate-400">{formatDate(lead.data.date)}</time>
          </div>
          <h2 class="text-xl font-extrabold text-slate-900 group-hover:text-brand-700 sm:text-2xl">{leadTitle}</h2>
          {leadDesc && <p class="mt-2 line-clamp-3 text-slate-600 text-sm">{leadDesc}</p>}
          <span class="mt-4 text-sm font-bold text-brand-700">Lees meer →</span>
        </div>
      </a>
    )}

    {/* 3-koloms grid */}
    {rest.length > 0 && (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {rest.map((p) => <BlogPostCard post={p} />)}
      </div>
    )}
  </Container>
</BaseLayout>
