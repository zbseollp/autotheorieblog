---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getHomepagePosts();
---
<BaseLayout
  title={`Alle artikelen — theorie tips & uitleg | ${SITE.name}`}
  description="Het complete archief van Autotheorieblog.nl — alle artikelen over het CBR theorie-examen."
>
  <!-- Header balk -->
  <section class="bg-brand-700 text-white">
    <Container class="py-8">
      <h1 class="text-2xl font-extrabold text-white sm:text-3xl">Alle artikelen</h1>
      <p class="mt-1 text-brand-100 text-sm">{posts.length} artikelen over het CBR theorie-examen</p>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">
    <div class="grid gap-8 lg:grid-cols-3">

      <!-- Artikelgrid: 2/3 breed -->
      <div class="lg:col-span-2">
        <div class="grid gap-4 sm:grid-cols-2">
          {posts.map((p) => <BlogPostCard post={p} />)}
        </div>
      </div>

      <!-- Sidebar -->
      <div class="flex flex-col gap-6">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h2 class="text-sm font-bold text-slate-700 mb-4">Categorieën</h2>
          <ul class="space-y-1">
            {[
              { label: "Gevaarherkenning", href: "/blog/" },
              { label: "Voorrangsregels", href: "/theorie-uitleg/" },
              { label: "Verkeerstekens", href: "/theorie-uitleg/" },
              { label: "Rijbewijs halen", href: "/rijbewijs-halen/" },
              { label: "Examen tips", href: "/blog/" },
              { label: "Code 95", href: "/blog/" },
            ].map((t) => (
              <li>
                <a href={t.href} class="flex items-center justify-between rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-50 hover:text-brand-700 transition-colors">
                  {t.label}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl bg-brand-700 p-5 text-white">
          <h2 class="font-bold mb-2">Theorie uitleg nodig?</h2>
          <p class="text-sm text-brand-100 leading-relaxed mb-4">Bekijk onze uitlegpagina's over verkeersregels.</p>
          <a href="/theorie-uitleg/" class="inline-flex w-full items-center justify-center rounded-lg bg-white px-4 py-2.5 text-sm font-bold text-brand-700 hover:bg-brand-50 transition-colors">
            Theorie uitleg →
          </a>
        </div>
      </div>
    </div>
  </Container>
</BaseLayout>
