---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { getRecentPosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getRecentPosts(8);
const [lead, second, third, ...rest] = posts;

const topics = [
  { label: "Gevaarherkenning", href: "/blog/" },
  { label: "Voorrangsregels", href: "/theorie-uitleg/" },
  { label: "Rijbewijs halen", href: "/rijbewijs-halen/" },
  { label: "Kosten examen", href: "/rijbewijs-halen/" },
  { label: "Faalangst examen", href: "/blog/" },
  { label: "Code 95", href: "/blog/" },
];
---
<!-- Editorial homepage: geen hero, magazine-structuur, serif typografie -->
<BaseLayout
  title={`${SITE.name} — alles over het CBR theorie-examen`}
  description={SITE.description}
>
  <Container class="py-(--spacing-section)">

    <!-- Editoriaal intro label -->
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-slate-900"></div>
      <span class="text-xs font-bold uppercase tracking-[0.3em] text-slate-500">Nieuwste artikelen</span>
      <div class="h-px flex-1 bg-slate-900"></div>
    </div>

    <!-- Hoofd 2-koloms layout -->
    <div class="grid gap-0 lg:grid-cols-3 lg:divide-x lg:divide-slate-200">

      <!-- Linkerkolom: uitgelicht artikel groot -->
      <div class="lg:col-span-2 lg:pr-10">
        {lead && (
          <a href={`/${lead.id}/`} class="group block mb-8 pb-8 border-b border-slate-200">
            <time class="text-xs font-bold uppercase tracking-widest text-brand-700">{formatDate(lead.data.date)}</time>
            <h2 style="font-family: var(--font-heading);" class="mt-2 text-3xl font-bold leading-tight text-slate-900 group-hover:text-brand-700 transition-colors sm:text-4xl">
              {displayTitle(lead)}
            </h2>
            {displayDescription(lead) && (
              <p class="mt-3 text-slate-600 leading-relaxed line-clamp-3 text-lg">{displayDescription(lead)}</p>
            )}
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-brand-700 group-hover:gap-2 transition-all">
              Lees het volledige artikel →
            </span>
          </a>
        )}

        <!-- Twee artikelen naast elkaar -->
        {(second || third) && (
          <div class="grid gap-6 sm:grid-cols-2 mb-8 pb-8 border-b border-slate-200">
            {[second, third].filter(Boolean).map((p) => p && (
              <a href={`/${p.id}/`} class="group block">
                <time class="text-xs font-semibold uppercase tracking-wider text-brand-600">{formatDate(p.data.date)}</time>
                <h3 style="font-family: var(--font-heading);" class="mt-1 text-xl font-bold text-slate-900 group-hover:text-brand-700 transition-colors leading-snug">
                  {displayTitle(p)}
                </h3>
                {displayDescription(p) && (
                  <p class="mt-2 text-sm text-slate-600 line-clamp-3 leading-relaxed">{displayDescription(p)}</p>
                )}
              </a>
            ))}
          </div>
        )}

        <!-- Meer artikelen als lijst -->
        {rest.length > 0 && (
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Meer artikelen</h3>
            <div class="space-y-0">
              {rest.slice(0, 3).map((p) => (
                <a href={`/${p.id}/`} class="group flex items-baseline gap-4 border-b border-slate-100 py-3 last:border-0">
                  <time class="shrink-0 text-xs text-slate-400 w-20">{formatDate(p.data.date)}</time>
                  <span style="font-family: var(--font-heading);" class="font-semibold text-slate-800 group-hover:text-brand-700 transition-colors leading-snug">{displayTitle(p)}</span>
                </a>
              ))}
            </div>
            <a href="/blog/" class="mt-5 inline-flex text-sm font-bold uppercase tracking-wider text-brand-700 hover:underline">
              Alle artikelen bekijken →
            </a>
          </div>
        )}
      </div>

      <!-- Rechterkolom: sidebar -->
      <div class="mt-10 lg:mt-0 lg:pl-10 flex flex-col gap-8 border-t border-slate-200 pt-8 lg:border-t-0 lg:pt-0">

        <!-- Over het blog -->
        <div>
          <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Over dit blog</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Autotheorieblog.nl schrijft over alles wat je nodig hebt voor het CBR theorie-examen: verkeersregels, gevaarherkenning en praktische tips.</p>
          <a href="/over-ons/" class="mt-3 inline-flex text-xs font-bold uppercase tracking-wider text-brand-700 hover:underline">Meer over ons →</a>
        </div>

        <!-- Onderwerpen -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px flex-1 bg-slate-200"></div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400">Onderwerpen</h3>
            <div class="h-px flex-1 bg-slate-200"></div>
          </div>
          <div class="flex flex-wrap gap-2">
            {topics.map((t) => (
              <a href={t.href} class="rounded-none border border-slate-300 px-3 py-1 text-xs font-medium text-slate-700 hover:border-brand-600 hover:text-brand-700 transition-colors">
                {t.label}
              </a>
            ))}
          </div>
        </div>

        <!-- CTA -->
        <div class="border-t-2 border-slate-900 pt-6">
          <div class="border-t border-slate-300 mb-4"></div>
          <p style="font-family: var(--font-heading);" class="text-xl font-bold text-slate-900 leading-snug">Klaar om te slagen voor je theorie?</p>
          <p class="mt-2 text-sm text-slate-600">Lees onze gratis artikelen en ga goed voorbereid het examen in.</p>
          <a href="/blog/" class="mt-4 inline-flex w-full items-center justify-center bg-brand-700 px-4 py-3 text-sm font-bold text-white hover:bg-brand-800 transition-colors">
            Alle artikelen
          </a>
        </div>
      </div>
    </div>

    <!-- Onderste rij: theorie-uitleg blok -->
    <div class="mt-12 pt-10 border-t-2 border-slate-900">
      <div class="border-t border-slate-300 mb-8"></div>
      <div class="flex items-center gap-4 mb-8">
        <h2 style="font-family: var(--font-heading);" class="text-2xl font-bold text-slate-900">Theorie onderwerpen</h2>
        <div class="h-px flex-1 bg-slate-200"></div>
        <a href="/theorie-uitleg/" class="text-xs font-bold uppercase tracking-wider text-brand-700 hover:underline">Bekijk alle →</a>
      </div>
      <div class="grid gap-px bg-slate-200 sm:grid-cols-2 lg:grid-cols-3 border border-slate-200">
        {[
          { nr: "01", title: "Voorrangsregels", sub: "Kruispunten, haaientanden en borden" },
          { nr: "02", title: "Gevaarherkenning", sub: "Herken en vermijd gevaarlijke situaties" },
          { nr: "03", title: "Verkeerstekens", sub: "Alle borden die je moet kennen" },
          { nr: "04", title: "Snelheidslimieten", sub: "Maximumsnelheden per wegtype" },
          { nr: "05", title: "Rijbewijs halen", sub: "Van lessen tot examen" },
          { nr: "06", title: "Examen tips", sub: "Slaag de eerste keer" },
        ].map((item) => (
          <a href="/theorie-uitleg/" class="group bg-white p-5 hover:bg-brand-50 transition-colors">
            <div class="text-3xl font-bold text-slate-100 group-hover:text-brand-200 transition-colors" style="font-family: var(--font-heading);">{item.nr}</div>
            <h3 class="mt-1 font-bold text-slate-900 group-hover:text-brand-700" style="font-family: var(--font-heading);">{item.title}</h3>
            <p class="mt-1 text-xs text-slate-500">{item.sub}</p>
          </a>
        ))}
      </div>
    </div>

  </Container>
</BaseLayout>
