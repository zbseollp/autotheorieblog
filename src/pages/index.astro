---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getRecentPosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getRecentPosts(7);
const [lead, ...grid] = posts;

const topics = [
  { icon: "🚦", label: "Voorrangsregels", sub: "Kruispunten & borden", href: "/theorie-uitleg/" },
  { icon: "⚠️", label: "Gevaarherkenning", sub: "Herken risicovolle situaties", href: "/blog/" },
  { icon: "🚗", label: "Rijbewijs halen", sub: "Van les tot examen", href: "/rijbewijs-halen/" },
  { icon: "📋", label: "Examen tips", sub: "Slaag de eerste keer", href: "/blog/" },
  { icon: "🛣️", label: "Verkeerstekens", sub: "Alle borden uitgelegd", href: "/theorie-uitleg/" },
  { icon: "🔄", label: "Code 95", sub: "Voor beroepschauffeurs", href: "/blog/" },
];

const faq = [
  { q: "Hoeveel vragen heeft het CBR theorie-examen?", a: "Het theorie-examen bestaat uit 65 meerkeuzevragen. Je moet minimaal 50 vragen goed hebben om te slagen — dat is een score van 77%." },
  { q: "Hoe lang duurt het theorie-examen?", a: "Je krijgt 30 minuten de tijd voor het examen. Gemiddeld zijn kandidaten er 20 minuten mee bezig." },
  { q: "Hoe vaak mag je het theorie-examen herhalen?", a: "Er is geen maximum aan het aantal pogingen. Je kunt het examen zo vaak doen als je wilt, maar je betaalt elke keer opnieuw examengeld." },
  { q: "Wat zijn de meest gemaakte fouten bij het theorie-examen?", a: "Gevaarherkenning en voorrangsregels zijn de onderdelen waar de meeste fouten worden gemaakt. Lees onze artikelen voor gerichte tips." },
];
---
<BaseLayout
  title={`${SITE.name} — tips & uitleg voor het CBR theorie-examen`}
  description={SITE.description}
>
  <!-- Hero balk -->
  <section class="bg-brand-700 text-white">
    <Container class="py-10 lg:py-14">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 rounded-full bg-brand-600 px-3 py-1 text-xs font-semibold text-brand-100 mb-4">
          CBR theorie-examen 2026
        </div>
        <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl leading-tight">
          Alles over het autotheorie-examen
        </h1>
        <p class="mt-4 text-brand-100 text-lg leading-relaxed max-w-xl">
          Praktische artikelen, tips en uitleg om je theorie-examen in één keer te halen.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/blog/" class="inline-flex items-center gap-2 rounded-lg bg-white px-5 py-2.5 text-sm font-bold text-brand-700 hover:bg-brand-50 transition-colors">
            Alle artikelen
          </a>
          <a href="/theorie-uitleg/" class="inline-flex items-center gap-2 rounded-lg border border-brand-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-600 transition-colors">
            Theorie uitleg
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Uitgelicht artikel + grid -->
  <Container class="py-(--spacing-section)">
    <div class="grid gap-8 lg:grid-cols-3">

      <!-- Hoofd: 2/3 breed -->
      <div class="lg:col-span-2">
        <h2 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Nieuwste artikel</h2>

        <!-- Uitgelicht kaart met stats naast de tekst -->
        {lead && (
          <div class="rounded-xl border border-slate-200 bg-white hover:border-brand-300 hover:shadow-md transition-all mb-6">
            <div class="grid sm:grid-cols-5">
              <!-- Tekst: 3/5 -->
              <a href={`/${lead.id}/`} class="group block p-6 sm:col-span-3 border-b sm:border-b-0 sm:border-r border-slate-100">
                <div class="flex items-center gap-2 mb-3">
                  <span class="inline-flex rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-semibold text-brand-700">Uitgelicht</span>
                  <time class="text-xs text-slate-400">{formatDate(lead.data.date)}</time>
                </div>
                <h3 class="text-xl font-bold text-slate-900 group-hover:text-brand-700 transition-colors leading-snug">{displayTitle(lead)}</h3>
                {displayDescription(lead) && (
                  <p class="mt-3 text-sm text-slate-500 leading-relaxed line-clamp-4">{displayDescription(lead)}</p>
                )}
                <div class="mt-5 inline-flex items-center gap-1.5 rounded-md bg-brand-700 px-4 py-2 text-sm font-semibold text-white group-hover:bg-brand-800 transition-colors">
                  Lees artikel
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </a>

              <!-- CBR examenstats: 2/5 -->
              <div class="p-6 sm:col-span-2 flex flex-col justify-center gap-5">
                <div class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">CBR theorie in cijfers</div>
                {[
                  { label: "Vragen", value: "65", sub: "meerkeuzevragen" },
                  { label: "Slagingsnorm", value: "77%", sub: "minimaal 50 goed" },
                  { label: "Tijdsduur", value: "30 min", sub: "gemiddeld 20 min" },
                  { label: "Slagingspercentage", value: "±52%", sub: "eerste poging" },
                ].map((stat) => (
                  <div class="flex items-baseline justify-between border-b border-slate-100 pb-3 last:border-0 last:pb-0">
                    <span class="text-xs text-slate-500">{stat.label}</span>
                    <div class="text-right">
                      <span class="text-base font-extrabold text-brand-700">{stat.value}</span>
                      <div class="text-xs text-slate-400">{stat.sub}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        <!-- Kleine artikelen grid -->
        {grid.length > 0 && (
          <div class="grid gap-4 sm:grid-cols-2">
            {grid.slice(0, 4).map((p) => <BlogPostCard post={p} />)}
          </div>
        )}

        <div class="mt-6 text-center">
          <a href="/blog/" class="inline-flex items-center gap-2 rounded-lg border border-brand-200 bg-brand-50 px-5 py-2.5 text-sm font-semibold text-brand-700 hover:bg-brand-100 transition-colors">
            Alle artikelen bekijken →
          </a>
        </div>
      </div>

      <!-- Sidebar: 1/3 -->
      <div class="flex flex-col gap-6">
        <!-- Onderwerpen -->
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h2 class="text-sm font-bold text-slate-700 mb-4 flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-600"><path d="M4 6h16M4 12h10M4 18h14"/></svg>
            Theorie onderwerpen
          </h2>
          <ul class="space-y-1">
            {topics.map((t) => (
              <li>
                <a href={t.href} class="flex items-center gap-3 rounded-lg p-2.5 hover:bg-brand-50 transition-colors group">
                  <span class="text-xl leading-none">{t.icon}</span>
                  <div>
                    <div class="text-sm font-semibold text-slate-800 group-hover:text-brand-700 transition-colors">{t.label}</div>
                    <div class="text-xs text-slate-400">{t.sub}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA blok -->
        <div class="rounded-xl bg-brand-700 p-5 text-white">
          <h2 class="font-bold text-lg leading-snug mb-2">Snel slagen voor je theorie?</h2>
          <p class="text-sm text-brand-100 leading-relaxed mb-4">Lees onze gratis artikelen en ga goed voorbereid naar het CBR.</p>
          <a href="/rijbewijs-halen/" class="inline-flex w-full items-center justify-center rounded-lg bg-white px-4 py-2.5 text-sm font-bold text-brand-700 hover:bg-brand-50 transition-colors">
            Rijbewijs halen →
          </a>
        </div>
      </div>
    </div>
  </Container>

  <!-- FAQ blok -->
  <section class="bg-white border-t border-slate-200">
    <Container class="py-(--spacing-section)">
      <div class="grid gap-10 lg:grid-cols-3">
        <!-- Kop links -->
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700 mb-4">Veelgestelde vragen</div>
          <h2 class="text-2xl font-extrabold text-slate-900 leading-tight">Vragen over het theorie-examen</h2>
          <p class="mt-3 text-sm text-slate-500 leading-relaxed">Alles wat je wilt weten voordat je naar het CBR gaat.</p>
          <a href="/blog/" class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 hover:underline">
            Meer lezen in het blog →
          </a>
        </div>
        <!-- Vragen rechts -->
        <div class="lg:col-span-2 grid gap-4 sm:grid-cols-2">
          {faq.map((item) => (
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
              <h3 class="font-bold text-slate-900 text-sm leading-snug mb-2">{item.q}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Stap 1-2-3 blok -->
  <section class="bg-slate-50 border-t border-slate-200">
    <Container class="py-(--spacing-section)">
      <h2 class="text-2xl font-extrabold text-slate-900 mb-8 text-center">Hoe haal je je rijbewijs?</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        {[
          { step: "1", title: "Theorie leren", desc: "Leer de verkeersregels, borden en gevaarherkenning via onze artikelen.", color: "bg-blue-50 border-blue-200", num: "text-blue-200", badge: "bg-blue-600" },
          { step: "2", title: "Oefenexamen", desc: "Oefen met officiële CBR-vragen tot je consistent 80%+ scoort.", color: "bg-brand-50 border-brand-200", num: "text-brand-200", badge: "bg-brand-600" },
          { step: "3", title: "Examen doen", desc: "Ga met vertrouwen naar het CBR en haal je theorie in één keer.", color: "bg-green-50 border-green-200", num: "text-green-200", badge: "bg-green-600" },
        ].map((item) => (
          <div class={`relative rounded-xl border p-6 ${item.color}`}>
            <span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-xs font-bold text-white mb-4 ${item.badge}`}>{item.step}</span>
            <h3 class="font-bold text-slate-900 mb-1">{item.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>
