---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getRecentPosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const recent = await getRecentPosts(7);
const [hero, ...rest] = recent;
const heroTitle = hero ? displayTitle(hero) : "";
const heroDesc = hero ? displayDescription(hero) : "";

const topics = [
  { title: "Theorie uitleg", desc: "Begrijp de verkeersregels en slaag voor het CBR-examen.", href: "/theorie-uitleg/", icon: "📖" },
  { title: "Rijbewijs halen", desc: "Van rijlessen tot examen: alles wat je moet weten.", href: "/rijbewijs-halen/", icon: "🚗" },
  { title: "Gevaarherkenning", desc: "Tips om gevaarherkenning tijdens het examen goed te doen.", href: "/blog/", icon: "⚠️" },
  { title: "Kosten & tarieven", desc: "Wat kost een rijbewijs en het CBR-examen in 2026?", href: "/blog/", icon: "💶" },
];

const jsonld = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Organization", "@id": `${SITE.url}/#org`, name: SITE.name, url: SITE.url },
    { "@type": "WebSite", "@id": `${SITE.url}/#website`, url: SITE.url, name: SITE.name, publisher: { "@id": `${SITE.url}/#org` }, inLanguage: "nl-NL" },
  ],
};
---
<BaseLayout
  title={`${SITE.name} — alles over het theorie-examen`}
  description={SITE.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />

  <!-- Hero: editorial met paarse balk -->
  <section class="relative -mt-16 overflow-hidden pt-16 md:-mt-20 md:pt-20">
    <div class="absolute inset-0 bg-[linear-gradient(170deg,var(--color-brand-900)_0%,var(--color-brand-700)_55%,var(--color-brand-500)_100%)]"></div>
    <Container class="relative py-(--spacing-section)">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-flex items-center rounded-full bg-white/15 px-4 py-1.5 text-sm font-semibold text-white">CBR theorie 2026 · Gratis uitleg</span>
        <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Alles over het<br />theorie-examen
        </h1>
        <p class="mt-4 text-lg text-brand-100">
          Praktische artikelen, tips en uitleg om jou te helpen slagen voor het CBR theorie-examen.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/blog/" class="inline-flex items-center rounded-xl bg-white px-6 py-3 font-semibold text-brand-700 transition hover:bg-brand-50">Alle artikelen lezen</a>
          <a href="/theorie-uitleg/" class="inline-flex items-center rounded-xl bg-brand-600/60 px-6 py-3 font-semibold text-white transition hover:bg-brand-600">Theorie uitleg →</a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Uitgelicht artikel -->
  {hero && (
    <section class="bg-slate-50 border-b border-slate-100">
      <Container class="py-(--spacing-section)">
        <h2 class="mb-6 text-xs font-bold uppercase tracking-widest text-brand-700">Uitgelicht artikel</h2>
        <a href={`/${hero.id}/`} class="group flex flex-col overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm hover:shadow-xl transition lg:flex-row">
          {hero.data.featuredImage ? (
            <img src={hero.data.featuredImage} alt={heroTitle}
                 width="800" height="450" loading="eager" fetchpriority="high"
                 class="h-56 w-full object-cover lg:h-auto lg:w-2/5 group-hover:brightness-95 transition" />
          ) : (
            <div class="h-56 w-full bg-gradient-to-br from-brand-700 to-brand-400 lg:h-auto lg:w-2/5 flex items-center justify-center">
              <span class="text-4xl font-extrabold text-white/20">BLOG</span>
            </div>
          )}
          <div class="flex flex-1 flex-col justify-center p-8">
            <time class="text-xs font-semibold text-brand-700">{formatDate(hero.data.date)}</time>
            <h3 class="mt-2 text-2xl font-extrabold text-slate-900 group-hover:text-brand-700 sm:text-3xl">{heroTitle}</h3>
            {heroDesc && <p class="mt-3 text-slate-600 line-clamp-3">{heroDesc}</p>}
            <span class="mt-5 inline-flex items-center text-sm font-bold text-brand-700">Lees het artikel →</span>
          </div>
        </a>
      </Container>
    </section>
  )}

  <!-- Topic cards -->
  <section>
    <Container class="py-(--spacing-section)">
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Populaire onderwerpen</h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {topics.map((t) => (
          <a href={t.href} class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 transition hover:border-brand-300 hover:shadow-lg">
            <span class="text-2xl">{t.icon}</span>
            <h3 class="mt-3 text-base font-bold text-slate-900 group-hover:text-brand-700">{t.title}</h3>
            <p class="mt-2 flex-1 text-sm text-slate-600">{t.desc}</p>
            <span class="mt-4 text-sm font-semibold text-brand-700">Lees meer →</span>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- Recente artikelen -->
  {rest.length > 0 && (
    <section class="bg-slate-50">
      <Container class="py-(--spacing-section)">
        <div class="flex items-end justify-between">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Recente artikelen</h2>
          <a href="/blog/" class="text-sm font-semibold text-brand-700 hover:underline">Alle artikelen →</a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {rest.slice(0, 6).map((p, i) => <BlogPostCard post={p} eager={i === 0} />)}
        </div>
      </Container>
    </section>
  )}

  <!-- CTA band -->
  <section class="bg-brand-700">
    <Container class="py-12 text-center">
      <h2 class="text-2xl font-extrabold text-white">Klaar om te slagen?</h2>
      <p class="mt-2 text-brand-100">Lees onze gratis artikelen en bereid je voor op het CBR theorie-examen.</p>
      <a href="/blog/" class="mt-6 inline-flex rounded-xl bg-white px-6 py-3 font-semibold text-brand-700 hover:bg-brand-50 transition">Alle artikelen bekijken</a>
    </Container>
  </section>
</BaseLayout>
