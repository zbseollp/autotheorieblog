---
import type { Post } from "@lib/posts";
import { displayTitle, displayDescription, formatDate } from "@lib/posts";
interface Props { post: Post; eager?: boolean }
const { post } = Astro.props;
const { date } = post.data;
const title = displayTitle(post);
const desc = displayDescription(post);
const href = `/${post.id}/`;
---
<!-- Editorial tekst-first kaart: geen afbeelding, serif titel, dunne regel -->
<article class="group border-b border-slate-200 py-6 last:border-0">
  <div class="flex items-start gap-5">
    <!-- Paars accent streepje links -->
    <div class="mt-1.5 h-full w-0.5 shrink-0 self-stretch bg-brand-300 group-hover:bg-brand-600 transition-colors" aria-hidden="true"></div>
    <div class="flex-1 min-w-0">
      <time datetime={date.toISOString()} class="text-xs font-semibold uppercase tracking-widest text-brand-700">{formatDate(date)}</time>
      <h2 class="mt-1 leading-snug" style="font-family: var(--font-heading);">
        <a href={href} class="text-xl font-bold text-slate-900 group-hover:text-brand-700 transition-colors sm:text-2xl">{title}</a>
      </h2>
      {desc && <p class="mt-2 line-clamp-2 text-sm text-slate-600 leading-relaxed">{desc}</p>}
      <a href={href} class="mt-3 inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-brand-700 hover:gap-2 transition-all">
        Lees artikel <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</article>
