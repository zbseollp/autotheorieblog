---
import type { Post } from "@lib/posts";
import { displayTitle, displayDescription, formatDate } from "@lib/posts";
interface Props { post: Post; eager?: boolean }
const { post, eager = false } = Astro.props;
const { featuredImage, featuredImageAlt, date } = post.data;
const fmImage = featuredImage;
const bodyImage = !fmImage
  ? post.body?.match(/<img[^>]+src=["']?([^"'\s>]+)["']?/i)?.[1]
  : undefined;
const image = fmImage ?? bodyImage;
const title = displayTitle(post);
const desc = displayDescription(post);
const href = `/${post.id}/`;
---
<!-- Paars accent bovenrand + minimale editorial stijl -->
<article class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white transition hover:shadow-lg hover:border-brand-200">
  <div class="h-1 w-full bg-brand-500 transition-all duration-300 group-hover:h-1.5 group-hover:bg-brand-600"></div>
  {image ? (
    <a href={href} class="block overflow-hidden" aria-label={title}>
      <img
        src={image}
        alt={featuredImageAlt || title}
        width="640" height="360"
        loading={eager ? "eager" : "lazy"}
        decoding={eager ? "sync" : "async"}
        class="aspect-video w-full object-cover transition duration-300 group-hover:scale-[1.03]"
      />
    </a>
  ) : (
    <a href={href} class="block overflow-hidden" aria-label={title}>
      <div class="relative flex aspect-video w-full items-center justify-center bg-gradient-to-br from-brand-700 to-brand-400">
        <span class="font-display text-2xl font-extrabold tracking-tight text-white/90">Autotheorie<span class="text-brand-200">Blog</span></span>
        <span class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.15),transparent_60%)]"></span>
      </div>
    </a>
  )}
  <div class="flex flex-1 flex-col p-5">
    <time datetime={date.toISOString()} class="text-xs font-semibold uppercase tracking-wide text-brand-600">{formatDate(date)}</time>
    <h2 class="mt-2 text-base font-bold leading-snug text-slate-900 line-clamp-2">
      <a href={href} class="hover:text-brand-700">{title}</a>
    </h2>
    {desc && <p class="mt-2 line-clamp-2 text-sm text-slate-600">{desc}</p>}
    <span class="mt-4 text-sm font-semibold text-brand-700">Lees artikel →</span>
  </div>
</article>
