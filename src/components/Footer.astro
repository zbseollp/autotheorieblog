---
import Container from "@components/Container.astro";
import CurrentYear from "@components/CurrentYear.astro";
import { SITE } from "@lib/site";
import { getRecentPosts, displayTitle } from "@lib/posts";
const recent = (await getRecentPosts(4)).map((p) => ({ slug: p.id, title: displayTitle(p) }));
---
<footer class="mt-(--spacing-section) bg-slate-900 text-slate-300">
  <Container class="py-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Merk -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white text-xs font-black">AT</div>
          <span class="font-bold text-white text-base">AutotheorieBlog</span>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed">Praktische tips en uitleg voor het CBR theorie-examen. Gratis te lezen.</p>
      </div>

      <!-- Recente artikelen -->
      <div class="lg:col-span-1">
        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Recente artikelen</h3>
        <ul class="space-y-2.5">
          {recent.map((p) => (
            <li>
              <a href={`/${p.slug}/`} class="text-sm text-slate-300 hover:text-white transition-colors line-clamp-2 leading-snug">{p.title}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Navigatie -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Navigatie</h3>
        <ul class="space-y-2">
          {SITE.nav.map((i) => (
            <li><a href={i.href} class="text-sm text-slate-300 hover:text-white transition-colors">{i.label}</a></li>
          ))}
          <li><a href="/sitemap/" class="text-sm text-slate-300 hover:text-white transition-colors">Sitemap</a></li>
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Snel naar</h3>
        <div class="flex flex-col gap-2">
          <a href="/blog/" class="flex items-center gap-2 rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-600 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h10M4 18h14"/></svg>
            Alle artikelen
          </a>
          <a href="/theorie-uitleg/" class="flex items-center gap-2 rounded-lg bg-slate-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-600 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l9 4.5v11L12 22l-9-4.5v-11L12 2z"/></svg>
            Theorie uitleg
          </a>
        </div>
      </div>
    </div>
  </Container>

  <div class="border-t border-slate-700">
    <Container class="flex flex-col items-center justify-between gap-2 py-4 text-xs text-slate-500 sm:flex-row">
      <p>© <CurrentYear /> {SITE.name} · Alle rechten voorbehouden</p>
      <div class="flex gap-4">
        <a href="/over-ons/" class="hover:text-slate-300 transition-colors">Over ons</a>
        <a href="/contact/" class="hover:text-slate-300 transition-colors">Contact</a>
      </div>
    </Container>
  </div>
</footer>
