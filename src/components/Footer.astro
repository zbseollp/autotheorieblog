---
import Container from "@components/Container.astro";
import CurrentYear from "@components/CurrentYear.astro";
import { SITE } from "@lib/site";
import { getRecentPosts, displayTitle } from "@lib/posts";
const recent = (await getRecentPosts(5)).map((p) => ({ slug: p.id, title: displayTitle(p) }));
---
<footer class="mt-(--spacing-section) border-t-2 border-slate-900">
  <!-- Dubbele lijn editorial -->
  <div class="border-t border-slate-300"></div>

  <Container class="py-12">
    <div class="grid gap-10 md:grid-cols-3">

      <!-- Over het blog -->
      <div>
        <div style="font-family: var(--font-heading);" class="text-xl font-bold text-slate-900 mb-4">Autotheorieblog.nl</div>
        <p class="text-sm text-slate-600 leading-relaxed">
          Praktische artikelen over het CBR theorie-examen. Leer de verkeersregels, begrijp de gevaarherkenning en slaag voor je rijbewijs.
        </p>
        <div class="mt-5 flex gap-4 text-xs font-semibold uppercase tracking-wider text-brand-700">
          <a href="/blog/" class="hover:underline">Blog</a>
          <a href="/theorie-uitleg/" class="hover:underline">Theorie</a>
          <a href="/rijbewijs-halen/" class="hover:underline">Rijbewijs</a>
        </div>
      </div>

      <!-- Recente artikelen -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Recente artikelen</h3>
        <ul class="space-y-3">
          {recent.map((p) => (
            <li class="border-b border-slate-100 pb-3 last:border-0">
              <a href={`/${p.slug}/`} style="font-family: var(--font-heading);" class="text-sm font-semibold text-slate-800 leading-snug hover:text-brand-700 transition-colors line-clamp-2">{p.title}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links + contact -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Navigatie</h3>
        <ul class="space-y-2 text-sm">
          {SITE.nav.map((i) => (
            <li><a href={i.href} class="text-slate-600 hover:text-brand-700 transition-colors">{i.label}</a></li>
          ))}
          <li><a href="/sitemap/" class="text-slate-600 hover:text-brand-700 transition-colors">Sitemap</a></li>
        </ul>
      </div>
    </div>
  </Container>

  <div class="border-t-2 border-slate-900">
    <div class="border-t border-slate-300"></div>
    <Container class="flex flex-col items-center justify-between gap-2 py-4 text-xs text-slate-500 sm:flex-row">
      <p>© <CurrentYear /> {SITE.name} · Alle rechten voorbehouden</p>
      <p class="italic" style="font-family: var(--font-heading);">Alles over het theorie-examen</p>
    </Container>
  </div>
</footer>
